# Server environment variables (copy to .env — never commit .env)

# Railway sets PORT automatically
PORT=5000
NODE_ENV=development

# Comma-separated frontend URLs allowed by CORS (Vercel + local dev)
# Example: https://your-app.vercel.app,http://localhost:3000
CLIENT_URL=http://localhost:3000

# Auth
JWT_SECRET=change-this-to-a-long-random-secret
JWT_EXPIRES_IN=8h

# MySQL — option A: individual variables (Railway MySQL plugin)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=medivance

# MySQL — option B: single connection URL (overrides DB_* if set)
# MYSQL_URL=mysql://user:password@host:port/database

# Set to true if your MySQL host requires SSL (common on cloud providers)
# DB_SSL=true
